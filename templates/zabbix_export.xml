            <macros>
                <macro>
                    <macro>{$UPS.BATTERY.LOW}</macro>
                    <value>20</value>
                    <description>Low battery charge threshold in percent.</description>
                </macro>
                <macro>
                    <macro>{$UPS.RUNTIME.MIN}</macro>
                    <value>300</value>
                    <description>Critical remaining runtime threshold in seconds.</description>
                </macro>
                <macro>
                    <macro>{$UPS.LOAD.MAX}</macro>
                    <value>80</value>
                    <description>Maximum recommended UPS load in percent.</description>
                </macro>
                <macro>
                    <macro>{$UPS.INPUT.MIN}</macro>
                    <value>200</value>
                    <description>Minimum acceptable input voltage.</description>
                </macro>
                <macro>
                    <macro>{$UPS.INPUT.MAX}</macro>
                    <value>250</value>
                    <description>Maximum acceptable input voltage.</description>
                </macro>
                <macro>
                    <macro>{$UPS.TEMP.MAX}</macro>
                    <value>40</value>
                    <description>Maximum acceptable UPS temperature in degrees Celsius.</description>
                </macro>
                <macro>
                    <macro>{$UPS.NODATA}</macro>
                    <value>5m</value>
                    <description>No-data interval used for communication-loss detection.</description>
                </macro>
