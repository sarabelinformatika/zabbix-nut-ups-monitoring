                            <uuid>83e1529dcf5849ff9145cc8071ed5b93</uuid>
                            <name>{#UPS}: NUT driver</name>
                            <type>ZABBIX</type>
                            <key>ups.driver[{#UPS}]</key>
                            <delay>1h</delay>
                            <history>7d</history>
                            <trends>0</trends>
                            <value_type>CHAR</value_type>
                            <description>NUT metric collected for discovered UPS {#UPS}: NUT driver.</description>
                            <preprocessing>
                                <step>
                                    <type>DISCARD_UNCHANGED_HEARTBEAT</type>
                                    <parameters>
                                        <parameter>1h</parameter>
