    <templates>
        <template>
            <uuid>e1fb80380a1746d88600ab77d4e2f8f6</uuid>
            <template>Template NUT UPS by Zabbix agent</template>
            <name>Template NUT UPS by Zabbix agent</name>
            <description>Monitors one or more USB-connected UPS devices through Network UPS Tools (NUT) and Zabbix Agent flexible UserParameters. Requires the supplied ups.discovery key and ups.*[*] UserParameters on the monitored Linux or Proxmox host.</description>
            <groups>
                <group>
                    <name>Templates/Power</name>
                </group>
            </groups>
            <discovery_rules>
                <discovery_rule>
                    <uuid>e3fcca242e8f4935b1036fb2a22a1b36</uuid>
                    <name>NUT UPS discovery</name>
                    <type>ZABBIX</type>
                    <key>ups.discovery</key>
                    <delay>1h</delay>
                    <lifetime>7d</lifetime>
                    <description>Discovers UPS identifiers returned by upsc -l.</description>
                    <item_prototypes>
                        <item_prototype>
                            <uuid>757e55256a2a464c93d95d93f6975683</uuid>
                            <name>{#UPS}: UPS status</name>
                            <type>ZABBIX</type>
                            <key>ups.status[{#UPS}]</key>
                            <delay>30s</delay>
                            <history>7d</history>
                            <trends>0</trends>
                            <value_type>CHAR</value_type>
                            <description>NUT metric collected for discovered UPS {#UPS}: UPS status.</description>
                            <preprocessing>
                                <step>
                                    <type>DISCARD_UNCHANGED_HEARTBEAT</type>
                                    <parameters>
                                        <parameter>1h</parameter>
                                    </parameters>
                                </step>
                            </preprocessing>
                            <tags>
                                <tag>
                                    <tag>component</tag>
                                    <value>ups</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </item_prototype>
                        <item_prototype>
                            <uuid>620db4e846f2440e8d0d2baa9f8beee6</uuid>
                            <name>{#UPS}: Battery charge</name>
                            <type>ZABBIX</type>
                            <key>ups.charge[{#UPS}]</key>
                            <delay>1m</delay>
                            <history>7d</history>
                            <trends>90d</trends>
                            <value_type>UNSIGNED</value_type>
                            <units>%</units>
                            <description>NUT metric collected for discovered UPS {#UPS}: Battery charge.</description>
                            <tags>
                                <tag>
                                    <tag>component</tag>
                                    <value>ups</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </item_prototype>
                        <item_prototype>
                            <uuid>68f70d0c735c4d0b880d34825b88b6e9</uuid>
                            <name>{#UPS}: Battery runtime</name>
                            <type>ZABBIX</type>
                            <key>ups.runtime[{#UPS}]</key>
                            <delay>1m</delay>
                            <history>7d</history>
                            <trends>90d</trends>
                            <value_type>UNSIGNED</value_type>
