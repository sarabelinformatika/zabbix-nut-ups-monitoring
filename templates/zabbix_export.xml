                    </item_prototypes>
                    <trigger_prototypes>
                        <trigger_prototype>
                            <uuid>3c041e4767594ce4be364b4b93a6aa9e</uuid>
                            <expression>find(/Template NUT UPS by Zabbix agent/ups.status[{#UPS}],,"like","OB")=1</expression>
                            <name>{#UPS}: UPS is running on battery</name>
                            <priority>AVERAGE</priority>
                            <description>The UPS reports On Battery (OB). Check utility power and remaining runtime.</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>availability</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
                        <trigger_prototype>
                            <uuid>135d3799fb4a4af2b1356a8fc042e748</uuid>
                            <expression>last(/Template NUT UPS by Zabbix agent/ups.charge[{#UPS}])&lt;{$UPS.BATTERY.LOW}</expression>
                            <name>{#UPS}: Battery charge is low</name>
                            <priority>HIGH</priority>
                            <description>Battery charge is below the configured threshold.</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>capacity</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
                        <trigger_prototype>
                            <uuid>f0d584aa16384cccb942de5c61287c76</uuid>
                            <expression>last(/Template NUT UPS by Zabbix agent/ups.runtime[{#UPS}])&gt;0 and last(/Template NUT UPS by Zabbix agent/ups.runtime[{#UPS}])&lt;{$UPS.RUNTIME.MIN}</expression>
                            <name>{#UPS}: Remaining runtime is critical</name>
                            <priority>HIGH</priority>
                            <description>Estimated battery runtime is below the configured safety threshold.</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>capacity</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
                        <trigger_prototype>
                            <uuid>1aaaf94111d64b0b8a47d0df03604aeb</uuid>
                            <expression>last(/Template NUT UPS by Zabbix agent/ups.load[{#UPS}])&gt;{$UPS.LOAD.MAX}</expression>
                            <name>{#UPS}: UPS load is high</name>
                            <priority>WARNING</priority>
                            <description>UPS output load exceeds the recommended threshold.</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>performance</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
                        <trigger_prototype>
                            <uuid>32da193ac30c4b58b24a09744fd3627c</uuid>
                            <expression>find(/Template NUT UPS by Zabbix agent/ups.status[{#UPS}],,"like","RB")=1</expression>
                            <name>{#UPS}: UPS requests battery replacement</name>
                            <priority>AVERAGE</priority>
                            <description>The UPS reports Replace Battery (RB).</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>notice</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
                        <trigger_prototype>
                            <uuid>7add1b91edd64aada076705afdb3a639</uuid>
                            <expression>nodata(/Template NUT UPS by Zabbix agent/ups.status[{#UPS}],{$UPS.NODATA})=1</expression>
                            <name>{#UPS}: NUT communication lost</name>
                            <priority>HIGH</priority>
                            <description>No UPS status data has been received within the configured period.</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>availability</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
                        <trigger_prototype>
                            <uuid>18c84e309d474e35a5e03f308107c83b</uuid>
                            <expression>(last(/Template NUT UPS by Zabbix agent/ups.input[{#UPS}])&gt;0 and last(/Template NUT UPS by Zabbix agent/ups.input[{#UPS}])&lt;{$UPS.INPUT.MIN}) or last(/Template NUT UPS by Zabbix agent/ups.input[{#UPS}])&gt;{$UPS.INPUT.MAX}</expression>
                            <name>{#UPS}: Input voltage is outside the recommended range</name>
                            <priority>WARNING</priority>
                            <description>UPS input voltage is outside the configured operating range.</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>performance</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
                        <trigger_prototype>
                            <uuid>e597df541ab44461abe536f147d030d0</uuid>
                            <expression>last(/Template NUT UPS by Zabbix agent/ups.temperature[{#UPS}])&gt;{$UPS.TEMP.MAX}</expression>
                            <name>{#UPS}: UPS temperature is high</name>
                            <priority>WARNING</priority>
                            <description>UPS-reported temperature exceeds the configured threshold. Available only when supported by the device.</description>
                            <tags>
                                <tag>
                                    <tag>scope</tag>
                                    <value>performance</value>
                                </tag>
                                <tag>
                                    <tag>ups</tag>
                                    <value>{#UPS}</value>
                                </tag>
                            </tags>
                        </trigger_prototype>
