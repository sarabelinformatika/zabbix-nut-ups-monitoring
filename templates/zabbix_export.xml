                        </item_prototype>
                        <item_prototype>
                            <uuid>137f8488705f48a8b1df3135888faf34</uuid>
                            <name>{#UPS}: UPS manufacturer</name>
                            <type>ZABBIX</type>
                            <key>ups.manufacturer[{#UPS}]</key>
                            <delay>1h</delay>
                            <history>7d</history>
                            <trends>0</trends>
